{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/armind.com.ua/:path*",
      "destination": "https://www.armind.com.ua/:path*",
      "permanent": true
    },
    {
      "source": "/armind.com.ua",
      "destination": "https://www.armind.com.ua/",
      "permanent": true
    },
    {
      "source": "/:path((?!sitemap\\.xml|robots\\.txt|favicon.*|apple-touch-icon.*|site\\.webmanifest).*)?",
      "destination": "https://www.armind.com.ua/:path",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "armind.com.ua"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

